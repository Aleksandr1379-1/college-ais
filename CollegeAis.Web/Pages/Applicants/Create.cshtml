@page
@model CollegeAis.Web.Pages.Applicants.CreateModel

<div class="py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="display-6 fw-bold mb-1">Добавить абитуриента</h1>
            <div class="text-muted">Заполни основные данные абитуриента</div>
        </div>

        <a class="btn btn-outline-secondary" asp-page="Index">← Назад к списку</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            @if (!ViewContext.ModelState.IsValid)
{
    <div asp-validation-summary="All" class="alert alert-danger mb-4" role="alert"></div>
}
<div class="col-md-3">
    <label class="form-label">Год набора *</label>
    <input class="form-control" asp-for="Applicant.AdmissionYear" type="number" />
    <span class="text-danger small" asp-validation-for="Applicant.AdmissionYear"></span>
</div>
            <form method="post">
                <div class="row g-3">
                    <!-- Фамилия -->
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold">Фамилия *</label>
                        <input class="form-control" asp-for="Applicant.LastName" />
                        <span class="text-danger small" asp-validation-for="Applicant.LastName"></span>
                    </div>

                    <!-- Имя -->
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold">Имя *</label>
                        <input class="form-control" asp-for="Applicant.FirstName" />
                        <span class="text-danger small" asp-validation-for="Applicant.FirstName"></span>
                    </div>

                    <!-- Отчество -->
                    <div class="col-12 col-md-4">
                        <label class="form-label">Отчество</label>
                        <input class="form-control" asp-for="Applicant.MiddleName" />
                        <span class="text-danger small" asp-validation-for="Applicant.MiddleName"></span>
                    </div>

                    <!-- СНИЛС -->
                    <div class="col-12 col-md-4">
                        <label class="form-label">СНИЛС</label>
                        <input class="form-control" asp-for="Applicant.Snils" placeholder="например: 123-456-789 00" />
                        <span class="text-danger small" asp-validation-for="Applicant.Snils"></span>
                    </div>

                    <!-- Дата рождения -->
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold">Дата рождения *</label>
                        <input class="form-control" asp-for="Applicant.BirthDate" type="date" />
                        <span class="text-danger small" asp-validation-for="Applicant.BirthDate"></span>
                    </div>

                    <!-- Пол -->
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold">Пол *</label>
                        <select class="form-select" asp-for="Applicant.Gender">
                            <option value="М">М</option>
                            <option value="Ж">Ж</option>
                        </select>
                        <span class="text-danger small" asp-validation-for="Applicant.Gender"></span>
                    </div>

                    <!-- Телефон -->
                    <div class="col-12 col-md-6">
                        <label class="form-label">Телефон</label>
                        <input class="form-control" asp-for="Applicant.Phone" placeholder="+7..." />
                        <span class="text-danger small" asp-validation-for="Applicant.Phone"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-12 col-md-6">
                        <label class="form-label">Email</label>
                        <input class="form-control" asp-for="Applicant.Email" placeholder="name@example.com" />
                        <span class="text-danger small" asp-validation-for="Applicant.Email"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                    <a class="btn btn-outline-secondary" asp-page="Index">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}