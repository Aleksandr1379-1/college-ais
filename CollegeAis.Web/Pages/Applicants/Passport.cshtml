@page
@model CollegeAis.Web.Pages.Applicants.PassportModel

<div class="py-4">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h1 class="h4 fw-bold mb-1">Паспортные данные</h1>
            <div class="text-muted">
                @Model.Applicant.LastName @Model.Applicant.FirstName @Model.Applicant.MiddleName
            </div>
        </div>

        <a class="btn btn-outline-secondary" asp-page="Card" asp-route-id="@Model.Applicant.Id">← В карточку</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            @if (!ViewContext.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
            }

            <form method="post">
                <input type="hidden" asp-for="ApplicantId" />

                <div class="row g-3">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Серия</label>
                        <input class="form-control"
                               asp-for="Passport.Series"
                               inputmode="numeric"
                               autocomplete="off"
                               maxlength="4"
                               pattern="\d{4}"
                               placeholder="0000" />
                        <span class="text-danger small" asp-validation-for="Passport.Series"></span>
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label">Номер</label>
                        <input class="form-control"
                               asp-for="Passport.Number"
                               inputmode="numeric"
                               autocomplete="off"
                               maxlength="6"
                               pattern="\d{6}"
                               placeholder="000000" />
                        <span class="text-danger small" asp-validation-for="Passport.Number"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Код подразделения</label>
                        <input class="form-control"
                               asp-for="Passport.DivisionCode"
                               inputmode="numeric"
                               autocomplete="off"
                               maxlength="7"
                               pattern="\d{3}-\d{3}"
                               placeholder="000-000" />
                        <span class="text-danger small" asp-validation-for="Passport.DivisionCode"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Кем выдан</label>
                        <input class="form-control" asp-for="Passport.IssuedBy" />
                        <span class="text-danger small" asp-validation-for="Passport.IssuedBy"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Дата выдачи</label>
                        <input class="form-control" asp-for="Passport.IssueDate" type="date" />
                        <span class="text-danger small" asp-validation-for="Passport.IssueDate"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Гражданство</label>
                        <select class="form-select"
                                asp-for="Passport.CitizenshipCountryId"
                                asp-items="Model.CitizenshipOptions">
                        </select>
                        <span class="text-danger small" asp-validation-for="Passport.CitizenshipCountryId"></span>
                    </div>

                    <!-- СНИЛС -->
                    <div class="col-12 col-md-4">
                        <label class="form-label">СНИЛС</label>
                        <input class="form-control" asp-for="Applicant.Snils" placeholder="например: 123-456-789 00" />
                        <span class="text-danger small" asp-validation-for="Applicant.Snils"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">ИНН</label>
                        <input class="form-control" asp-for="Passport.Inn" />
                        <span class="text-danger small" asp-validation-for="Passport.Inn"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Место рождения</label>
                        <input class="form-control" asp-for="Passport.PlaceOfBirth" />
                        <span class="text-danger small" asp-validation-for="Passport.PlaceOfBirth"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" type="submit">Сохранить</button>
                    <a class="btn btn-outline-secondary" asp-page="Card" asp-route-id="@Model.ApplicantId">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

    function attachDigitsOnly(selector, maxLen) {
        const input = document.querySelector(selector);
        if (!input) return;

        function normalize() {
            input.value = (input.value || "")
                .replace(/\D/g, "")
                .slice(0, maxLen);
        }

        input.addEventListener("input", normalize);
        input.addEventListener("paste", () => setTimeout(normalize, 0));
    }

    // Серия: 4 цифры
    attachDigitsOnly('input[name="Passport.Series"]', 4);

    // Номер: 6 цифр
    attachDigitsOnly('input[name="Passport.Number"]', 6);
});

document.addEventListener("DOMContentLoaded", () => {
    const input = document.querySelector('input[name="Passport.DivisionCode"]');
    if (!input) return;

    const format = (value) => {
        const digits = (value || "").replace(/\D/g, "").slice(0, 6);
        return digits.length <= 3
            ? digits
            : digits.slice(0, 3) + "-" + digits.slice(3);
    };

    input.addEventListener("input", () => {
        const pos = input.selectionStart ?? input.value.length;

        const before = input.value;
        const beforeDigitsCount = before.slice(0, pos).replace(/\D/g, "").length;

        input.value = format(before);

        let newPos = beforeDigitsCount;
        if (beforeDigitsCount > 3) newPos += 1;

        input.setSelectionRange(newPos, newPos);
    });

    input.addEventListener("paste", (e) => {
        e.preventDefault();
        const text = (e.clipboardData || window.clipboardData).getData("text");
        input.value = format(text);
    });
});
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}