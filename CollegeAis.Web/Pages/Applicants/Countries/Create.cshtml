@page
@model CollegeAis.Web.Pages.Applicants.Countries.CreateModel

<div class="py-4">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h1 class="h4 fw-bold mb-1">Добавить страну</h1>
            <div class="text-muted">Страна появится в выборе “Гражданство”</div>
        </div>
        <a class="btn btn-outline-secondary" asp-page="Index">← Назад</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Название</label>
                    <input class="form-control" asp-for="Input.Name" placeholder="Например: Российская Федерация" />
                    <span class="text-danger small" asp-validation-for="Input.Name"></span>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" type="submit">Сохранить</button>
                    <a class="btn btn-outline-secondary" asp-page="Index">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}