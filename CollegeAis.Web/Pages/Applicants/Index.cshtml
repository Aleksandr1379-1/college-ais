@page
@model CollegeAis.Web.Pages.Applicants.IndexModel
@using CollegeAis.Web.Helpers

<div class="py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h1 class="display-6 fw-bold mb-1">Абитуриенты</h1>
            <div class="text-muted">Список абитуриентов приёмной комиссии</div>
        </div>

        <a class="btn btn-primary" asp-page="Create">
            + Добавить абитуриента
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-12 col-md-6 col-lg-7">
                    <label class="form-label mb-1">Поиск</label>
                    <input name="q" value="@Model.Q" class="form-control"
                           placeholder="ФИО, телефон или email" />
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label mb-1">Статус</label>
                    <select class="form-select" name="status">
                        <option value="">Все</option>
                        @foreach (var s in Enum.GetValues(typeof(CollegeAis.Data.Enums.ApplicantStatus)))
                        {
                            var selected = Model.Status?.ToString() == s.ToString();
                            <option value="@s" selected="@selected">
                                @(((CollegeAis.Data.Enums.ApplicantStatus)s).ToRu())
                            </option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-2 col-lg-2 d-grid">
                    <button class="btn btn-outline-primary" type="submit">Применить</button>
                </div>
            </form>

            <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted small">
                    Найдено: <span class="fw-semibold">@Model.Applicants.Count</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Q) || Model.Status.HasValue)
                {
                    <a class="btn btn-sm btn-outline-secondary" asp-page="Index">Сбросить</a>
                }
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ФИО</th>
                        <th class="text-nowrap">Дата рождения</th>
                        <th class="text-nowrap">Телефон</th>
                        <th class="text-nowrap">Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>

                <tbody>
                @if (Model.Applicants.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            Ничего не найдено
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Applicants)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">
                                    <a class="text-decoration-none"
                                       asp-page="Card"
                                       asp-route-id="@item.Id">
                                        @item.LastName @item.FirstName @item.MiddleName
                                    </a>
                                </div>
                                <div class="text-muted small">
                                    Создан: @item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </div>
                            </td>

                            <td class="text-nowrap">
                                @item.BirthDate.ToString("dd.MM.yyyy")
                            </td>

                            <td class="text-nowrap">
                                @(string.IsNullOrWhiteSpace(item.Phone) ? "—" : item.Phone)
                            </td>

                            <td class="text-nowrap">
                                <span class="badge rounded-pill @GetStatusBadge(item.Status)">
                                    @item.Status.ToRu()
                                </span>
                            </td>

                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-page="Card"
                                       asp-route-id="@item.Id">
                                        Карточка
                                    </a>
                                    <a class="btn btn-sm btn-outline-secondary"
                                       asp-page="Edit"
                                       asp-route-id="@item.Id">
                                        Редактировать
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

    @functions {
        private string GetStatusBadge(CollegeAis.Data.Enums.ApplicantStatus status)
        {
            return status switch
            {
            CollegeAis.Data.Enums.ApplicantStatus.Draft => "text-bg-secondary",
            CollegeAis.Data.Enums.ApplicantStatus.Submitted => "text-bg-primary",
            CollegeAis.Data.Enums.ApplicantStatus.InRating => "text-bg-info",
            CollegeAis.Data.Enums.ApplicantStatus.Enrolled => "text-bg-success",
            CollegeAis.Data.Enums.ApplicantStatus.Withdrawn => "text-bg-danger",
            CollegeAis.Data.Enums.ApplicantStatus.ExcludedFromRating => "text-bg-warning",
            _ => "text-bg-dark"
            };
        }
    }
}