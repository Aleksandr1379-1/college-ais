@page
@model CollegeAis.Web.Pages.Applicants.IndexModel

<div class="py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div>
            <h1 class="display-6 fw-bold mb-1">Абитуриенты</h1>
            <div class="text-muted">Список абитуриентов приёмной комиссии</div>
        </div>

        <a class="btn btn-primary" asp-page="Create">
            + Добавить абитуриента
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ФИО</th>
                            <th class="text-nowrap">Дата рождения</th>
                            <th>Телефон</th>
                            <th>Статус</th>
                            <th class="text-end" style="width: 140px;">Действия</th>
                        </tr>
                    </thead>

                    <tbody>
                    @if (Model.Applicants == null || Model.Applicants.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Пока нет записей. Нажми <b>“Добавить абитуриента”</b>.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Applicants)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">
                                        @item.LastName @item.FirstName @item.MiddleName
                                    </div>
                                    <div class="text-muted small">
                                        ID: @item.Id
                                    </div>
                                </td>

                                <td class="text-nowrap">@item.BirthDate</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Phone) ? "—" : item.Phone)</td>

                                <td>
                                    @{
                                        var badge = item.Status.ToString() switch
                                        {
                                            "Draft" => "bg-secondary-subtle text-secondary",
                                            "Submitted" => "bg-info-subtle text-info",
                                            "Accepted" => "bg-success-subtle text-success",
                                            "Rejected" => "bg-danger-subtle text-danger",
                                            _ => "bg-light text-dark"
                                        };
                                    }
                                    <span class="badge @badge">
                                        @item.Status
                                    </span>
                                </td>

                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-page="Edit"
                                       asp-route-id="@item.Id">
                                        Редактировать
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>