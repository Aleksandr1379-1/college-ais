@page
@model CollegeAis.Web.Pages.Applicants.IndexModel

<h1>Абитуриенты</h1>

<p>
    <a asp-page="Create">Добавить нового</a>
</p>

<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>ФИО</th>
            <th>Дата рождения</th>
            <th>Телефон</th>
            <th>Статус</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Applicants)
    {
        <tr>
            <td>@item.LastName @item.FirstName @item.MiddleName</td>
            <td>@item.BirthDate</td>
            <td>@item.Phone</td>
            <td>@item.Status</td>
            <td>
                <a asp-page="Edit" asp-route-id="@item.Id">Редактировать</a>
            </td>
        </tr>
    }
    </tbody>
</table>
