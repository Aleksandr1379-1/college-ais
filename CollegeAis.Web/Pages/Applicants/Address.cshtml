@page
@model CollegeAis.Web.Pages.Applicants.AddressModel

<div class="py-4">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h1 class="h4 fw-bold mb-1">Адреса и общежитие</h1>
            <div class="text-muted">
                @Model.Applicant.LastName @Model.Applicant.FirstName @Model.Applicant.MiddleName
            </div>
        </div>

        <a class="btn btn-outline-secondary" asp-page="Card" asp-route-id="@Model.Applicant.Id">← В карточку</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            @if (!ViewContext.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
            }

            <form method="post">
                <input type="hidden" asp-for="ApplicantId" />

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Адрес прописки</label>
                        <textarea class="form-control" rows="2" asp-for="Address.RegistrationAddress"></textarea>
                        <span class="text-danger small" asp-validation-for="Address.RegistrationAddress"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Фактический адрес</label>
                        <textarea class="form-control" rows="2" asp-for="Address.ActualAddress"></textarea>
                        <span class="text-danger small" asp-validation-for="Address.ActualAddress"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" asp-for="Address.NeedsDormitory" />
                            <label class="form-check-label">Нужно общежитие</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" type="submit">Сохранить</button>
                    <a class="btn btn-outline-secondary" asp-page="Card" asp-route-id="@Model.ApplicantId">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}