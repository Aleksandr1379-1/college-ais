@page
@model CollegeAis.Web.Pages.Programs.IndexModel

<div class="py-4">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h1 class="h4 fw-bold mb-1">Справочник специальностей</h1>
            <div class="text-muted">Код, название и параметры обучения</div>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-primary" asp-page="Create">+ Добавить</a>
            <a class="btn btn-outline-secondary" asp-page="/Index">← На главную</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (Model.Programs.Count == 0)
            {
                <div class="text-muted">Пока нет ни одной специальности</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:140px;">Код</th>
                                <th style="min-width:280px;">Название</th>
                                <th style="min-width:220px;">Квалификация</th>
                                <th style="min-width:220px;">Базовое образование</th>
                                <th style="width:140px;">Срок</th>
                                <th style="width:170px;">Бюджет</th>
                                <th style="width:170px;">Платно</th>
                                <th style="width:140px;">Используется</th>
                                <th style="width:240px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Programs)
                            {
                                <tr>
                                    <td class="fw-semibold">@p.Code</td>
                                    <td class="fw-semibold">@p.Name</td>
                                    <td>@(p.Qualification ?? "—")</td>
                                    <td>@(p.BaseEducation ?? "—")</td>
                                    <td>@(p.StudyDuration ?? "—")</td>
                                    <td>@p.BudgetSeats</td>
                                    <td>@p.PaidSeats</td>
                                    <td>@p.UsedCount</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary"
                                           asp-page="Edit"
                                           asp-route-id="@p.Id">Редактировать</a>
                                        <a class="btn btn-sm btn-outline-danger"
                                           asp-page="Delete"
                                           asp-route-id="@p.Id">Удалить</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>