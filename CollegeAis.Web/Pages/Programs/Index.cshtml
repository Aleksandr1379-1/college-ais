@page
@model CollegeAis.Web.Pages.Programs.IndexModel

<h1>Специальности</h1>

<p>
    <a asp-page="Create">Добавить специальность</a>
</p>

<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>Код</th>
            <th>Название</th>
            <th>Уровень</th>
            <th>Активна</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model.Programs)
    {
        <tr>
            <td>@p.Code</td>
            <td>@p.Name</td>
            <td>@p.EducationLevel</td>
            <td>@(p.IsActive ? "Да" : "Нет")</td>
        </tr>
    }
    </tbody>
</table>