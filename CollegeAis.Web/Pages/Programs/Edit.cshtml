@page
@model CollegeAis.Web.Pages.Programs.EditModel

<div class="py-4">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h1 class="h4 fw-bold mb-1">Редактировать специальность</h1>
            <div class="text-muted">Изменения сразу применятся в заявлениях</div>
        </div>
        <a class="btn btn-outline-secondary" asp-page="Index">← Назад</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form method="post">
                <div class="row g-3">
                    <div class="col-12 col-md-3">
                        <label class="form-label">Код</label>
                        <input class="form-control" asp-for="Input.Code" />
                        <span class="text-danger small" asp-validation-for="Input.Code"></span>
                    </div>

                    <div class="col-12 col-md-9">
                        <label class="form-label">Название</label>
                        <input class="form-control" asp-for="Input.Name" />
                        <span class="text-danger small" asp-validation-for="Input.Name"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Квалификация</label>
                        <input class="form-control" asp-for="Input.Qualification" placeholder="Например: программист" />
                        <span class="text-danger small" asp-validation-for="Input.Qualification"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Базовое образование</label>
                        <input class="form-control" asp-for="Input.BaseEducation" placeholder="9 классов / 11 классов" />
                        <span class="text-danger small" asp-validation-for="Input.BaseEducation"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Срок обучения</label>
                        <input class="form-control" asp-for="Input.StudyDuration" placeholder="3г 10м" />
                        <span class="text-danger small" asp-validation-for="Input.StudyDuration"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Бюджетных мест</label>
                        <input class="form-control" asp-for="Input.BudgetSeats" type="number" min="0" />
                        <span class="text-danger small" asp-validation-for="Input.BudgetSeats"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Платных мест</label>
                        <input class="form-control" asp-for="Input.PaidSeats" type="number" min="0" />
                        <span class="text-danger small" asp-validation-for="Input.PaidSeats"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" type="submit">Сохранить</button>
                    <a class="btn btn-outline-secondary" asp-page="Index">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}